[0.222, "o", "-- Seshat Agreement — agent permissions, deny-by-default.\r\n-- Facts available: actor, action, scope \u001b[1m(\u001b[0mscope is \u001b[32m\"none\"\u001b[0m when the call has no project/group \r\ntarget\u001b[1m)\u001b[0m.\r\n-- No permit match = denied. A forbid always wins over a permit.\r\n\r\npermit actor is \u001b[32m\"claude-code\"\u001b[0m and action is \u001b[32m\"start_project\"\u001b[0m\r\npermit actor is \u001b[32m\"claude-code\"\u001b[0m and action is \u001b[32m\"stop_project\"\u001b[0m\r\npermit actor is \u001b[32m\"claude-code\"\u001b[0m and action is \u001b[32m\"start_group\"\u001b[0m\r\npermit actor is \u001b[32m\"claude-code\"\u001b[0m and action is \u001b[32m\"stop_group\"\u001b[0m\r\npermit actor is \u001b[32m\"claude-code\"\u001b[0m and action is \u001b[32m\"register_project\"\u001b[0m\r\n\r\nforbid action is \u001b[32m\"stop_orphan\"\u001b[0m because \u001b[32m\"orphan termination stays in the dashboard\"\u001b[0m\r\nforbid action is \u001b[32m\"set_secret\"\u001b[0m because \u001b[32m\"agents cannot modify secrets\"\u001b[0m\r\n\r\n"]
